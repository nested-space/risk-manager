# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
*.whl
# Except the vendored dmta-cli wheel, a required non-PyPI dependency bundled in
# lib/ (see pyproject.toml dependencies) so the project installs from a clean clone.
!lib/*.whl

# Virtual environments (project venv lives at ~/.venvs/riskmanager — outside repo)
.venv/
venv/
env/
ENV/
.env

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml
pytest.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Linting
.ruff_cache/

# SQLite database files (never commit DB data)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Session state (user-local, outside repo by default)
.rmgr/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Jupyter Notebooks
.ipynb_checkpoints/

# Alembic (migrations are committed; compiled artefacts are not)
alembic/__pycache__/

# Build system
*.manifest
*.spec

# Logs
*.log
